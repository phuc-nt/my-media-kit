{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyMediaKit",
  "version": "0.1.0",
  "identifier": "tech.lighton.media.MyMediaKit",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "My Media Kit",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc://localhost https: wss:; img-src 'self' data: blob:; media-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxOEJGMDc0RkIyMjZCRDYKUldUV2F5TDdkUENMd2JlNlMydXZQazNBNURZSk1oSFlZeEo2UWZTQ2hnSEVuRk1wdXhQaGJyaW0K",
      "endpoints": [
        "https://github.com/phuc-nt/my-media-kit/releases/latest/download/latest.json"
      ]
    }
  }
}
